<section class="content-card">
    <div>
        <p class="eyebrow">Security</p>
        <h2>Change your password</h2>
        <p class="muted-copy">Protect the account with a fresh password and current-password confirmation.</p>
    </div>

    <%= form_with model: Current.user, url: settings_password_path, class: "form-grid" do |form| %>
        <% if form.object.errors.any? %>
            <div class="danger-zone"><%= form.object.errors.full_messages.first %></div>
        <% end %>

        <div class="field-row">
            <%= form.label :password_challenge %>
            <%= form.password_field :password_challenge, required: true, autocomplete: "current-password" %>
        </div>

        <div class="field-row">
            <%= form.label :password %>
            <%= form.password_field :password, required: true, autocomplete: "new-password" %>
        </div>

        <div class="field-row">
            <%= form.label :password_confirmation %>
            <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password" %>
        </div>

        <div class="form-actions">
            <%= form.submit "Update password", class: "button primary-button" %>
        </div>
    <% end %>
</section>