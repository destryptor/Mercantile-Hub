<%= content_for :content do %>
    <section class="settings-shell">
        <aside class="settings-sidebar">
            <div class="settings-sidebar-header">
                <p class="eyebrow">Control center</p>
                <h2>Account settings</h2>
                <p>Update your profile, security, and store management tools from one place.</p>
            </div>

            <nav class="settings-nav" aria-label="Settings navigation">
                <div class="settings-nav-group">
                    <h4>Account Settings</h4>
                    <%= link_to "Profile", settings_profile_path, class: settings_nav_link_class(settings_profile_path) %>
                    <%= link_to "Email", settings_email_path, class: settings_nav_link_class(settings_email_path) %>
                    <%= link_to "Password", settings_password_path, class: settings_nav_link_class(settings_password_path) %>
                    <%= link_to "Account", settings_user_path, class: settings_nav_link_class(settings_user_path) %>
                </div>

                <% if Current.user.admin? %>
                    <div class="settings-nav-group">
                        <h4>Store Settings</h4>
                        <%= link_to "Products", store_products_path, class: settings_nav_link_class(store_products_path) %>
                        <%= link_to "Users", store_users_path, class: settings_nav_link_class(store_users_path) %>
                        <%= link_to "Subscribers", store_subscribers_path, class: settings_nav_link_class(store_subscribers_path) %>
                        <%= link_to "Wishlists", store_wishlists_path, class: settings_nav_link_class(store_wishlists_path) %>
                        <%= link_to "Sidekiq", sidekiq_web_path, class: settings_nav_link_class(sidekiq_web_path) %>
                    </div>
                <% end %>
            </nav>
        </aside>

        <div class="settings-content card-surface">
            <%= yield %>
        </div>
    </section>
<% end %>

<%= render template: "layouts/application" %>